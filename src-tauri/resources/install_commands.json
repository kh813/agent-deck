{
  "agy": {
    "name": "Antigravity CLI",
    "binary": "agy",
    "detect_paths": {
      "macos": [
        "$HOME/.local/bin/agy",
        "/usr/local/bin/agy",
        "/opt/homebrew/bin/agy",
        "$HOME/.gemini/antigravity-cli/bin/agy"
      ],
      "windows": [
        "$USERPROFILE\\AppData\\Local\\agy\\bin\\agy.exe",
        "$USERPROFILE\\.gemini\\antigravity-cli\\bin\\agy.exe",
        "$USERPROFILE\\AppData\\Local\\antigravity-cli\\bin\\agy.exe"
      ]
    },
    "version_args": ["--version"],
    "install": {
      "macos": {
        "command": "bash",
        "args": ["-c", "curl -fsSL https://antigravity.google/cli/install.sh | bash"]
      },
      "windows": {
        "command": "powershell.exe",
        "args": ["-Command", "Set-ExecutionPolicy -Scope Process -ExecutionPolicy Bypass -Force; $tmp = Join-Path $env:TEMP ('antigravity-install-' + [guid]::NewGuid().ToString() + '.ps1'); Invoke-WebRequest -UseBasicParsing -Uri https://antigravity.google/cli/install.ps1 -OutFile $tmp; try { & $tmp } finally { Remove-Item $tmp -ErrorAction SilentlyContinue }"]
      }
    },
    "update": {
      "macos": {
        "command": "agy",
        "args": ["self-update"]
      },
      "windows": {
        "command": "agy.exe",
        "args": ["self-update"]
      }
    }
  },
  "claude": {
    "name": "Claude Code",
    "binary": "claude",
    "detect_paths": {
      "macos": [
        "/opt/homebrew/bin/claude",
        "/usr/local/bin/claude",
        "$HOME/.npm-global/bin/claude"
      ],
      "windows": [
        "$USERPROFILE\\AppData\\Roaming\\npm\\claude.cmd"
      ]
    },
    "version_args": ["--version"]
  },
  "codex": {
    "name": "Codex",
    "binary": "codex",
    "detect_paths": {
      "macos": [
        "/opt/homebrew/bin/codex",
        "/usr/local/bin/codex",
        "$HOME/.npm-global/bin/codex"
      ],
      "windows": [
        "$USERPROFILE\\AppData\\Roaming\\npm\\codex.cmd"
      ]
    },
    "version_args": ["--version"]
  }
}
