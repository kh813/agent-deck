# Python (bundled skills + automation code)
/app/venv/
__pycache__/
*.pyc
*.pyo
python/**/__pycache__/
/skills/*.skill
python/scripts/automation/logs/
python/scripts/automation/ChromeUserData/
python/scripts/automation/scheduled/

# Personal skill layer — per-installation, never committed
python/skills-personal/*
!python/skills-personal/.gitkeep

# Generated cache (rebuilt by skills_catalog.py)
python/skills/skill-catalog/catalog-index.md

# Private configuration (template stays tracked)
/config.toml
/client_secret_*.json

# Company/admin-only reference docs (this project's own working directory
# doubles as an organization's private dev environment — see
# docs/admin_guide.md §0). Not part of the OSS project itself.
/docs/

# Org-specific agy project instructions (not part of the OSS project --
# each deployment supplies its own, or none at all).
/ANTIGRAVITY.md

# Self-updater / release-bundling artifacts written at the project root.
# agent-ui.* covers a pre-2026-07-16 local build/test artifact (before the
# agent-ui -> agent-deck rename); agent-deck.* is the current name.
/agent-ui.app
/agent-ui.app.version
/agent-ui.exe
/agent-ui.exe.version
/agent-deck.app
/agent-deck.app.version
/agent-deck.exe
/agent-deck.exe.version

# Runtime artifacts created by setup.py at first launch
/app/bin/
/.gemini/
/files/*
!/files/.gitkeep
/tmp/
